# App
APP_MODE=console
APP_USER=user1

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=whatsapp_bot
DB_USER=postgres
DB_PASSWORD=postgres
DB_CONNECT_TIMEOUT=5
DB_GSSENCMODE=disable

# SSH tunnel (optional)
SSH_ENABLED=false
SSH_HOST=your.server.host
SSH_PORT=22
SSH_USERNAME=ubuntu
SSH_PRIVATE_KEY_PATH=/absolute/path/to/id_rsa
SSH_PASSPHRASE=
SSH_REMOTE_DB_HOST=127.0.0.1
SSH_REMOTE_DB_PORT=5432
SSH_LOCAL_BIND_HOST=127.0.0.1
SSH_LOCAL_BIND_PORT=6543

# WhatsApp Selenium
WA_ENABLED=false
WA_WEB_URL=https://web.whatsapp.com/
WA_CHROME_BINARY=
WA_CHROMEDRIVER_PATH=
WA_CHROMEDRIVER_VERSION=
WA_CHROME_USER_DATA_DIR=
WA_DEFAULT_CHAT=
WA_POLL_INTERVAL_SEC=3
WA_AUTH_TIMEOUT_SEC=300
WA_ALLOW_OUTGOING_TEST=false
WA_DEBUG_LOGS=false
